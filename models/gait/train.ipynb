        "\n",
        "            nn.Dropout(0.30),\n",
        "        )\n",
        "\n",
        "        self.lstm = nn.LSTM(\n",
        "            input_size=64,\n",
        "            hidden_size=64,\n",
        "            batch_first=True\n",
        "        )\n",
        "\n",
        "        self.dropout = nn.Dropout(0.30)\n",
        "\n",
        "        self.fc = nn.Linear(\n",
